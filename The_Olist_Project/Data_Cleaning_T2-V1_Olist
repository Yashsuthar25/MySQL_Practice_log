SELECT *
FROM
 olist_database.olist_geolocation;

 -- this below checks for the Length of the geolocation_zip,  columns.
 SELECT 
  geolocation_zip_code_prefix,
  geolocation_state
FROM
 olist_database.olist_geolocation
WHERE
 LENGTH(geolocation_state) <> 2 OR
 LENGTH(geolocation_zip_code_prefix) <> 4 AND
 LENGTH(geolocation_zip_code_prefix) <> 5;
 -- The output is '0', But the metadata says the Zip_code length should be exactly 10, which is not correct, let's cross verifty.

 DESCRIBE olist_database.olist_geolocation;

 -- The next query will check for the latitude & longitude's because those should be between -90 & 90 and -180 & 180 respectively.
 SELECT 
  geolocation_lat,
  geolocation_lng
FROM 
 olist_database.olist_geolocation
WHERE
 geolocation_lat NOT BETWEEN -90 AND 90 OR
 geolocation_lng NOT BETWEEN -180 AND 180;

