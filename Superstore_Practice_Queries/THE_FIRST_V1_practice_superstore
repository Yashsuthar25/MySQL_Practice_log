/* In the below query, I'll join 2 tables Customers & Sales data, I'll find out the top 10 buyers for all the years, 
I'll be breaking this into sytematic approach */
SELECT 
 Customer_Name, 
 Category,
 EXTRACT(Year FROM Order_Date) AS Year_of_purchase,
 Sales AS Top_10_Clients
FROM
 superstore.superstore_sales_data AS Sales
LEFT JOIN 
 superstore.customers AS Customers
ON
 Sales.Customer_Name = Customers.Customer_Name
GROUP BY
 Customer_Name, Category, Year_of_purchase
ORDER BY
 Sales DESC
LIMIT
 10;
 
