-- Now, we use HAVING instead of WHERE clause, because it lets us filter the data after the aggregation is done.
SELECT 
 Product_Name, 
  SUM(Sales) AS Total_sales,
FROM 
 superstore.superstore_sales_data
GROUP BY 
 Product_Name
HAVING
 Tota_sales > (SELECT AVG(Sales) 
                 FROM superstore.superstore_sales_data
                 GROUP BY Product_Name) AS avg_sales;

